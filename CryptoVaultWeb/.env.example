# ─── Supabase ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Encryption ─────────────────────────────────────────────────────────
# Strong random string used as AES encryption salt
VITE_ENCRYPTION_SECRET=your-very-long-random-secret-string-min-32-chars

# ─── Ethereum ────────────────────────────────────────────────────────────
VITE_ETH_MAINNET_RPC=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
VITE_ETH_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# ─── Binance Smart Chain ─────────────────────────────────────────────────
VITE_BSC_MAINNET_RPC=https://bsc-dataseed1.binance.org/
VITE_BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/

# ─── Polygon ─────────────────────────────────────────────────────────────
VITE_POLYGON_MAINNET_RPC=https://polygon-rpc.com/
VITE_POLYGON_MUMBAI_RPC=https://rpc-mumbai.maticvigil.com/

# ─── Block Explorers (for tx links) ──────────────────────────────────────
VITE_ETH_MAINNET_EXPLORER=https://etherscan.io
VITE_ETH_SEPOLIA_EXPLORER=https://sepolia.etherscan.io
VITE_BSC_MAINNET_EXPLORER=https://bscscan.com
VITE_BSC_TESTNET_EXPLORER=https://testnet.bscscan.com
VITE_POLYGON_MAINNET_EXPLORER=https://polygonscan.com
VITE_POLYGON_MUMBAI_EXPLORER=https://mumbai.polygonscan.com

# ─── NEW in v2 ───────────────────────────────────────────────────────────────

# 0x Protocol (Swap) — get free key at https://dashboard.0x.org
VITE_ZEROX_API_KEY=your-0x-api-key

# Alchemy (NFTs) — get free key at https://alchemy.com
VITE_ALCHEMY_ETH_KEY=your-alchemy-eth-key
VITE_ALCHEMY_SEPOLIA_KEY=your-alchemy-sepolia-key
VITE_ALCHEMY_POLYGON_KEY=your-alchemy-polygon-key
VITE_ALCHEMY_AMOY_KEY=your-alchemy-amoy-key

# Moralis (NFT fallback) — get free key at https://moralis.io
VITE_MORALIS_API_KEY=your-moralis-key

# MoonPay (Buy Crypto) — get free test key at https://moonpay.com/dashboard
VITE_MOONPAY_API_KEY=pk_test_your-moonpay-key

# Transak (Buy Crypto) — get free key at https://transak.com
VITE_TRANSAK_API_KEY=your-transak-key

# Ramp Network (Buy Crypto) — get free key at https://ramp.network
VITE_RAMP_API_KEY=your-ramp-key

# Polygon Amoy Testnet (replaces deprecated Mumbai)
VITE_POLYGON_AMOY_RPC=https://rpc.ankr.com/polygon_amoy

# CoinGecko Pro (optional - increases rate limit from 30 to 500 req/min)
VITE_COINGECKO_API_KEY=your-coingecko-pro-key
